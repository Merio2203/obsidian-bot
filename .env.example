# Telegram
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_OWNER_ID=123456789

# RouterAI
ROUTERAI_API_KEY=your_routerai_key_here

# Google Calendar
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_CALENDAR_IDS=tasks_calendar_id,personal_calendar_id,family_calendar_id
GOOGLE_TOKEN_FILE=/app/data/google_token.json

# Vault
VAULT_PATH=/app/vault
DROPBOX_VAULT_PATH=/Приложения/remotely-save/ObsidianVault

# Timezone
TIMEZONE=Europe/Moscow

# Optional
DATABASE_URL=sqlite+aiosqlite:////app/data/bot.db
LOG_FILE=/app/data/bot.log
AI_MAX_RETRIES=2
AI_RETRY_DELAY_SECONDS=2
